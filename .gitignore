.DS_Store
*.user
node_modules/

# Local env vars loaded by Makefile (DEVELOPER_TEAM_ID, NOTARY_PROFILE).
# See .env.example for the expected keys.
.env

# vst/ build output
vst/build/

# m4l engine/host TypeScript build output — regenerate with `pnpm -r build`
m4l/engine/dist/
m4l/host/dist/

# m4l n4m bundle output — regenerate with `pnpm bundle:host` (or `pnpm bake`).
# Source is m4l/pointsman.entry.mjs (tracked). See ADR 002 §Phase 0.
m4l/pointsman.mjs

# Versioned un-frozen .amxd staged by `make release-m4l VERSION=X.Y.Z`.
# Ephemeral release helper — the user opens it in Max, Freezes, and
# Save-As's into dist/. m4l/Pointsman.amxd (the unversioned dev bake
# target) stays committed.
m4l/Pointsman-v*.amxd

# Frozen distribution `.amxd` (release target). Produced by
# `make release-m4l VERSION=X.Y.Z` + manual Freeze step in Max. dist/ is
# for frozen / signed-and-notarized artefacts only. See ADR 002 §Phase 0.
dist/

# Ableton Live project folder (auto-created on first device load, named
# after the .amxd: Pointsman Project/)
m4l/Pointsman Project/
