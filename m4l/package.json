{
  "name": "@pointsman/m4l",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Pointsman M4L target — pnpm workspace root for engine, host, and scripts packages.",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "bundle:host": "esbuild pointsman.entry.mjs --bundle --platform=node --format=esm --external:max-api --outfile=pointsman.mjs",
    "bake": "pnpm -r build && pnpm bundle:host && node scripts/maxpat-to-amxd.mjs",
    "bake:check": "node scripts/maxpat-to-amxd.mjs --check"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.24.0"
  }
}
