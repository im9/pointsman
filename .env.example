# Copy to `.env` (gitignored) and fill in. Loaded automatically by the
# root Makefile via `-include .env` + `export`, propagated to recipe
# sub-shells so vst/scripts/build-*.sh + codesign.sh + notarize.sh can
# read them. Plain KEY=VALUE only — no quotes, no comments inside .env
# itself (the file is parsed as Makefile syntax).

# Apple Developer team identifier (10-char alphanumeric). Required by
# codesign.sh / notarize.sh / build-dmg.sh / build-pkg.sh.
DEVELOPER_TEAM_ID=

# Optional: NOTARY_PROFILE — keychain profile name created via
# `xcrun notarytool store-credentials`. Defaults to `im9-notary`
# (shared across im9 plugins) if unset; only add a line here to override.
